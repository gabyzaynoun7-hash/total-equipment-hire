<!DOCTYPE html>
<html lang="en-AU">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | {{ site.name }}</title>
  <meta name="description" content="{{ description or site.tagline }}">
  <meta name="keywords" content="equipment hire, restoration equipment, drying equipment, flood damage, water damage, air movers, dehumidifiers, Sydney, {{ site.suburb }}">
  <meta name="author" content="{{ site.name }}">

  <!-- Open Graph -->
  <meta property="og:title" content="{{ title }} | {{ site.name }}">
  <meta property="og:description" content="{{ description or site.tagline }}">
  <meta property="og:image" content="{{ site.logoPng }}">
  <meta property="og:type" content="website">
  <meta property="og:locale" content="en_AU">

  <!-- Canonical -->
  <link rel="canonical" href="https://totalequipmenthire.com.au{{ page.url }}">

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="{{ site.logoPng }}">

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

  <!-- Styles -->
  <link rel="stylesheet" href="/css/style.css">

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "{{ site.name }}",
    "description": "{{ site.tagline }}",
    "telephone": "{{ site.phone }}",
    "email": "{{ site.email }}",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "{{ site.suburb }}",
      "addressRegion": "NSW",
      "addressCountry": "AU"
    },
    "areaServed": [
      {% for area in site.areas %}
      {
        "@type": "City",
        "name": "{{ area }}"
      }{% if not loop.last %},{% endif %}
      {% endfor %}
    ],
    "openingHoursSpecification": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
      "opens": "00:00",
      "closes": "23:59"
    },
    "image": "{{ site.logoPng }}",
    "url": "https://totalequipmenthire.com.au"
  }
  </script>
</head>
<body>

  <!-- Header -->
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="header-logo">
        <img src="{{ site.logoPng }}" alt="{{ site.name }}" width="180" height="45">
      </a>

      <nav class="header-nav" aria-label="Main navigation">
        <a href="/" class="nav-link">Home</a>
        <a href="/services" class="nav-link">Services</a>
        <a href="/about" class="nav-link">About</a>
        <a href="/gallery" class="nav-link">Gallery</a>
        <a href="/contact" class="nav-link">Contact</a>
      </nav>

      <div class="header-actions">
        <a href="tel:{{ site.phoneTel }}" class="header-phone">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          {{ site.phone }}
        </a>
        <a href="/contact" class="btn btn-primary header-cta">Get a Quote</a>
      </div>

      <button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </header>

  <!-- Mobile Navigation -->
  <div class="mobile-nav" aria-hidden="true">
    <nav class="mobile-nav-links">
      <a href="/" class="nav-link">Home</a>
      <a href="/services" class="nav-link">Services</a>
      <a href="/about" class="nav-link">About</a>
      <a href="/gallery" class="nav-link">Gallery</a>
      <a href="/contact" class="nav-link">Contact</a>
      <a href="tel:{{ site.phoneTel }}" class="btn btn-primary mobile-cta">Call {{ site.phone }}</a>
    </nav>
  </div>

  <!-- Main Content -->
  <main>
    {{ content | safe }}
  </main>

  <!-- Footer -->
  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-col">
          <img src="{{ site.logoPng }}" alt="{{ site.name }}" class="footer-logo" width="160" height="40">
          <p class="footer-description">{{ site.tagline }}</p>
          <p class="footer-description">Serving all of Sydney with professional restoration and drying equipment, 24 hours a day, 7 days a week.</p>
        </div>

        <div class="footer-col">
          <h3 class="footer-heading">Quick Links</h3>
          <ul class="footer-links">
            <li><a href="/">Home</a></li>
            <li><a href="/services">Our Services</a></li>
            <li><a href="/about">About Us</a></li>
            <li><a href="/gallery">Equipment Gallery</a></li>
            <li><a href="/contact">Contact Us</a></li>
          </ul>
        </div>

        <div class="footer-col">
          <h3 class="footer-heading">Contact Us</h3>
          <ul class="footer-contact">
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
              <a href="tel:{{ site.phoneTel }}">{{ site.phone }}</a>
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
              <a href="mailto:{{ site.email }}">{{ site.email }}</a>
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
              {{ site.suburb }}, {{ site.state }}
            </li>
          </ul>
          <p class="footer-emergency">
            <strong>24/7 Emergency:</strong><br>
            <a href="tel:{{ site.phoneTel }}" class="emergency-phone">{{ site.phone }}</a>
          </p>
        </div>
      </div>

      <div class="footer-bottom">
        <p>&copy; {{ 2026 }} {{ site.name }}. All rights reserved.</p>
        <p>Website by <a href="https://tradiespark.com.au" target="_blank" rel="noopener">TradieSpark</a></p>
      </div>
    </div>
  </footer>

  <!-- Netlify Identity Widget (for CMS login) -->
  <script>
    if (window.netlifyIdentity) {
      window.netlifyIdentity.on("init", function(user) {
        if (!user) {
          window.netlifyIdentity.on("login", function() {
            document.location.href = "/admin/";
          });
        }
      });
    }
  </script>
  <script async src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>

  <!-- Scripts -->
  <script src="/js/main.js"></script>
</body>
</html>
