---
layout: base.njk
title: "Restoration & Drying Equipment Hire Sydney"
description: "Professional restoration equipment hire across Sydney. Air movers, dehumidifiers, air scrubbers & extraction machines. Fast delivery. 24/7 emergency. Call 0452 092 221."
---

<!-- Hero Section -->
<section class="hero" style="background-image: linear-gradient(rgba(17,17,17,0.75), rgba(17,17,17,0.75)), url('{{ site.heroPhoto }}');">
  <div class="container hero-content">
    <h1 class="hero-title fade-in">Sydney's Trusted Equipment Hire for Flood &amp; Water Damage</h1>
    <p class="hero-subtitle fade-in">{{ site.shortDescription }}</p>
    <div class="hero-buttons fade-in">
      <a href="/contact" class="btn btn-primary btn-lg">Get a Free Quote</a>
      <a href="tel:{{ site.phoneTel }}" class="btn btn-outline btn-lg">Call Now: {{ site.phone }}</a>
    </div>
  </div>
</section>

<!-- Services Overview -->
<section class="section" id="services">
  <div class="container">
    <div class="section-header fade-in">
      <h2>Our Equipment</h2>
      <p>Professional-grade restoration and drying equipment available for hire across Sydney</p>
    </div>

    <div class="services-grid" data-stagger>
      {% for service in services %}
      <div class="service-card fade-in">
        <div class="service-icon">
          {% if service.icon == "wind" %}
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.59 4.59A2 2 0 1 1 11 8H2m10.59 11.41A2 2 0 1 0 14 16H2m15.73-8.27A2.5 2.5 0 1 1 19.5 12H2"/></svg>
          {% elif service.icon == "droplet" %}
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/></svg>
          {% elif service.icon == "shield" %}
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          {% elif service.icon == "waves" %}
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 6c.6.5 1.2 1 2.5 1C7 7 7 5 9.5 5c2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg>
          {% elif service.icon == "gauge" %}
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20z"/><path d="M12 6v6l4 2"/></svg>
          {% elif service.icon == "zap" %}
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          {% elif service.icon == "clock" %}
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          {% endif %}
        </div>
        <h3 class="service-card-title">{{ service.name }}</h3>
        <p class="service-card-text">{{ service.shortDescription }}</p>
        <a href="/services#{{ service.slug }}" class="service-card-link">Learn More</a>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Why Choose Us -->
<section class="section section-light">
  <div class="container">
    <div class="section-header fade-in">
      <h2>Why Choose Total Equipment Hire</h2>
    </div>

    <div class="trust-grid" data-stagger>
      <div class="trust-item fade-in">
        <div class="trust-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <h3>24/7 Emergency Hire</h3>
        <p>Equipment available around the clock. Call anytime for urgent flood and water damage situations.</p>
      </div>

      <div class="trust-item fade-in">
        <div class="trust-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        </div>
        <h3>Fast Sydney-Wide Delivery</h3>
        <p>Rapid equipment delivery across all Sydney metro regions. We get to you when you need it.</p>
      </div>

      <div class="trust-item fade-in">
        <div class="trust-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3>Professional Grade Equipment</h3>
        <p>Industrial-quality air movers, dehumidifiers, and extraction machines maintained to the highest standard.</p>
      </div>

      <div class="trust-item fade-in">
        <div class="trust-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <h3>Trusted by Professionals</h3>
        <p>Plumbers, builders, and restoration companies across Sydney rely on us for quality equipment.</p>
      </div>
    </div>
  </div>
</section>

<!-- Service Areas -->
<section class="section section-dark areas-section">
  <div class="container">
    <div class="section-header fade-in">
      <h2>We Service All of Sydney</h2>
      <p>Fast equipment delivery across every major Sydney region</p>
    </div>

    <div class="areas-grid fade-in">
      {% for area in site.areas %}
      <span class="area-badge">{{ area }}</span>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Emergency CTA Banner -->
<section class="cta-banner">
  <div class="container text-center">
    <h2 class="cta-title">Need Emergency Equipment?</h2>
    <p class="cta-text">We're available 24/7 for urgent flood and water damage situations across Sydney</p>
    <a href="tel:{{ site.phoneTel }}" class="cta-phone">Call {{ site.phone }}</a>
    <div class="cta-buttons">
      <a href="/contact" class="btn btn-white btn-lg">Get a Free Quote</a>
    </div>
  </div>
</section>
