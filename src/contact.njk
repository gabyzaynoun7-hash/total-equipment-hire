---
layout: base.njk
title: "Contact Us — 24/7 Emergency Equipment Hire Sydney"
description: "Contact Total Equipment Hire for restoration and drying equipment hire across Sydney. Available 24/7 for emergencies. Call 0452 092 221 or fill out our form."
permalink: /contact/
---

<!-- Page Header -->
<section class="page-header">
  <div class="container">
    <h1 class="fade-in">Contact Us</h1>
    <nav class="breadcrumb fade-in">
      <a href="/">Home</a> / <span>Contact</span>
    </nav>
  </div>
</section>

<!-- Contact Section -->
<section class="section">
  <div class="container">
    <div class="contact-grid">
      <!-- Contact Form -->
      <div class="contact-form-wrapper fade-in">
        <h2>Get a Free Quote</h2>
        <p>Fill out the form below and we'll get back to you within 2 hours. For emergencies, call us directly.</p>

        <form class="contact-form" action="{{ site.formspreeEndpoint }}" method="POST">
          <!-- Honeypot for spam protection -->
          <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off">
          <!-- Formspree settings -->
          <input type="hidden" name="_subject" value="New Enquiry — Total Equipment Hire Website">

          <div class="form-group">
            <label for="name">Full Name <span class="required">*</span></label>
            <input type="text" id="name" name="name" required placeholder="Your full name">
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="email">Email <span class="required">*</span></label>
              <input type="email" id="email" name="email" required placeholder="your@email.com">
            </div>
            <div class="form-group">
              <label for="phone">Phone <span class="required">*</span></label>
              <input type="tel" id="phone" name="phone" required placeholder="04XX XXX XXX">
            </div>
          </div>

          <div class="form-group">
            <label for="equipment">Equipment Required</label>
            <select id="equipment" name="equipment_type">
              <option value="">Select equipment type...</option>
              <option value="Air Movers">Air Movers</option>
              <option value="Dehumidifiers">Dehumidifiers</option>
              <option value="Air Scrubbers">Air Scrubbers</option>
              <option value="Flood Extraction">Flood Extraction Equipment</option>
              <option value="Moisture Detection">Moisture Detection Equipment</option>
              <option value="Water Pumps">Water Pumps</option>
              <option value="Emergency Package">24/7 Emergency Package</option>
              <option value="Multiple/Other">Multiple Items / Other</option>
            </select>
          </div>

          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="5" placeholder="Tell us about your situation — location, type of damage, equipment needed, urgency..."></textarea>
          </div>

          <button type="submit" class="btn btn-primary btn-lg btn-full">
            <span class="btn-text">Send Enquiry</span>
            <span class="btn-loading" style="display:none;">Sending...</span>
          </button>
        </form>

        <div class="form-success" style="display:none;">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <h3>Enquiry Sent Successfully!</h3>
          <p>Thanks for your enquiry! We'll get back to you within 2 hours.</p>
          <p>For emergencies, call us directly at <a href="tel:{{ site.phoneTel }}"><strong>{{ site.phone }}</strong></a></p>
        </div>

        <div class="form-error" style="display:none;">
          <h3>Something went wrong</h3>
          <p>Please try again or call us directly at <a href="tel:{{ site.phoneTel }}"><strong>{{ site.phone }}</strong></a></p>
        </div>
      </div>

      <!-- Contact Info -->
      <div class="contact-info fade-in">
        <div class="contact-info-card">
          <h3>Get In Touch</h3>

          <div class="contact-info-item">
            <div class="contact-info-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            </div>
            <div>
              <strong>Phone</strong>
              <a href="tel:{{ site.phoneTel }}">{{ site.phone }}</a>
            </div>
          </div>

          <div class="contact-info-item">
            <div class="contact-info-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            </div>
            <div>
              <strong>Email</strong>
              <a href="mailto:{{ site.email }}">{{ site.email }}</a>
            </div>
          </div>

          <div class="contact-info-item">
            <div class="contact-info-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            </div>
            <div>
              <strong>Location</strong>
              <span>{{ site.suburb }}, {{ site.state }}</span>
            </div>
          </div>

          <div class="contact-info-item">
            <div class="contact-info-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div>
              <strong>Hours</strong>
              <span>24/7 — Always Available</span>
            </div>
          </div>

          <div class="contact-emergency">
            <h4>Emergency Equipment Hire</h4>
            <p>Need equipment urgently? Call us now — we're available 24/7.</p>
            <a href="tel:{{ site.phoneTel }}" class="btn btn-primary btn-full">Call {{ site.phone }}</a>
          </div>
        </div>

        <!-- Google Maps -->
        <div class="contact-map">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d26524.83396020653!2d151.06803!3d-33.8712!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x6b12bb1b0c473f09%3A0x5017d681632bdc0!2sStrathfield%20NSW%202135!5e0!3m2!1sen!2sau!4v1"
            width="100%"
            height="250"
            style="border:0; border-radius: 8px;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Total Equipment Hire location — Strathfield, NSW">
          </iframe>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Service Areas -->
<section class="section section-dark areas-section">
  <div class="container">
    <div class="section-header fade-in">
      <h2>Service Areas</h2>
      <p>We deliver equipment across all of Sydney</p>
    </div>
    <div class="areas-grid fade-in">
      {% for area in site.areas %}
      <span class="area-badge">{{ area }}</span>
      {% endfor %}
    </div>
  </div>
</section>
