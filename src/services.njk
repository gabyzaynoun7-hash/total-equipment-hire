---
layout: base.njk
title: "Equipment Hire Services — Air Movers, Dehumidifiers & More"
description: "Professional restoration equipment hire services in Sydney. Air movers, dehumidifiers, air scrubbers, flood extraction, moisture detection, water pumps. 24/7 emergency hire."
permalink: /services/
---

<!-- Page Header -->
<section class="page-header">
  <div class="container">
    <h1 class="fade-in">Our Services</h1>
    <nav class="breadcrumb fade-in">
      <a href="/">Home</a> / <span>Services</span>
    </nav>
  </div>
</section>

<!-- Services Intro -->
<section class="section">
  <div class="container">
    <div class="section-header fade-in">
      <h2>Professional Equipment for Every Restoration Job</h2>
      <p>From minor leaks to major flood events, we have the right equipment to get the job done efficiently and effectively.</p>
    </div>
  </div>
</section>

<!-- Individual Service Sections -->
{% for service in services %}
<section class="section {% if loop.index0 % 2 == 1 %}section-light{% endif %}" id="{{ service.slug }}">
  <div class="container">
    <div class="service-detail {% if loop.index0 % 2 == 1 %}service-detail-reverse{% endif %}">
      <div class="service-detail-content fade-in {% if loop.index0 % 2 == 1 %}fade-in-right{% else %}fade-in-left{% endif %}">
        <div class="service-detail-number">0{{ loop.index }}</div>
        <h2>{{ service.name }}</h2>
        <p>{{ service.description }}</p>
        <ul class="service-features">
          {% for feature in service.features %}
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F26522" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            {{ feature }}
          </li>
          {% endfor %}
        </ul>
        <a href="/contact" class="btn btn-primary">Enquire About This Equipment</a>
      </div>
      <div class="service-detail-image fade-in">
        <div class="service-image-placeholder">
          {% if service.icon == "wind" %}
          <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="#F26522" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9.59 4.59A2 2 0 1 1 11 8H2m10.59 11.41A2 2 0 1 0 14 16H2m15.73-8.27A2.5 2.5 0 1 1 19.5 12H2"/></svg>
          {% elif service.icon == "droplet" %}
          <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="#F26522" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/></svg>
          {% elif service.icon == "shield" %}
          <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="#F26522" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          {% elif service.icon == "waves" %}
          <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="#F26522" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 6c.6.5 1.2 1 2.5 1C7 7 7 5 9.5 5c2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg>
          {% elif service.icon == "gauge" %}
          <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="#F26522" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20z"/><path d="M12 6v6l4 2"/></svg>
          {% elif service.icon == "zap" %}
          <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="#F26522" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          {% elif service.icon == "clock" %}
          <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="#F26522" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>
{% endfor %}

<!-- CTA Banner -->
<section class="cta-banner">
  <div class="container text-center">
    <h2 class="cta-title">Need Equipment Fast?</h2>
    <p class="cta-text">Contact us for a free quote or call for 24/7 emergency hire</p>
    <a href="tel:{{ site.phoneTel }}" class="cta-phone">{{ site.phone }}</a>
    <div class="cta-buttons">
      <a href="/contact" class="btn btn-white btn-lg">Get a Free Quote</a>
    </div>
  </div>
</section>
